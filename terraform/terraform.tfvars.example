# ─────────────────────────────────────────────────────────────────────────────
# terraform.tfvars  —  copy this file to terraform.tfvars and fill in
# ⚠️  NEVER commit terraform.tfvars — it contains real secrets
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS ───────────────────────────────────────────────────────────────────────
aws_region          = "us-east-1"
project_name        = "lmns"
instance_type       = "t3.medium"
root_volume_size_gb = 30

ami_id = "ami-0905a3c97561e0b69"

# Restrict to your IP for security
allowed_ssh_cidr = ["0.0.0.0/0"]   # e.g. ["1.2.3.4/32"]

# ── App repo ──────────────────────────────────────────────────────────────────
# Public repo — no token needed. Branch to deploy (default: main).
app_repo_url    = "https://github.com/cosmic-chimps/bella-baxter"
app_repo_branch = "main"

# ── RDS ───────────────────────────────────────────────────────────────────────
db_instance_class = "db.t3.micro"
db_name           = "appdb"
db_username       = "appuser"
# db_password is generated by Terraform (random_password) — no need to set it here

# ── Bella Baxter ──────────────────────────────────────────────────────────────
bella_baxter_url = "https://api.your-bella-instance.com"

# Long-lived API key scoped to look-ma-no-secrets/production
# WebApp → look-ma-no-secrets → production → API Keys → Create
bella_app_api_key = "bax-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"






# Bella project and environment (must already exist — created by demo-seed.sh)
bella_project = "look-ma-no-secrets"
bella_env     = "production"

# Which Bella provider to write secrets to (e.g. "baxter-openbao")
# Find the slug in WebApp → Providers
bella_provider_slug = "baxter-openbao"

# App name for resource tagging
app_name = "look-ma-no-secrets-demo"

# SSH users the Bella certificate will be valid for (comma-separated)
ssh_allowed_users = "ubuntu"
